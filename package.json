{
    "name": "crud-api",
    "version": "1.0.0",
    "description": "A simple CRUD API",
    "main": "dist/app.js",
    "scripts": {
        "start:dev": "cross-env NODE_ENV=development ts-node src/load-balancer/loadBalancer.ts",
        "start:prod": "npm run build && node dist/app.js",
        "start:multi": "ts-node src/load-balancer/loadBalancer.ts",
        "build": "webpack --config webpack.config.js",
        "test": "jest"
    },
    "dependencies": {
        "dotenv": "^16.0.0",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^20.0.0",
        "@types/uuid": "^9.0.0",
        "axios": "^1.9.0",
        "cross-env": "^7.0.3",
        "eslint": "^8.0.0",
        "eslint-config-prettier": "^8.0.0",
        "eslint-plugin-prettier": "^4.0.0",
        "jest": "^29.0.0",
        "nodemon": "^3.0.0",
        "prettier": "^3.0.0",
        "ts-jest": "^29.0.0",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.0.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.0.0",
        "webpack": "^5.0.0",
        "webpack-cli": "^5.0.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "transform": {
            "^.+\\.tsx?$": "ts-jest"
        },
        "moduleFileExtensions": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "json",
            "node"
        ],
        "roots": [
            "<rootDir>/src"
        ]
    }
}
